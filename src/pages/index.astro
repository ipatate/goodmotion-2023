---
import data from "../../data";
import Layout from "../layouts/BaseLayout.astro";
import Advantages from "../components/home/Advantages.astro";
import HeroHome from "../components/home/HeroHome.astro";
import LogoBlock from "../components/home/LogoBlock.astro";
import Services from "../components/home/Services.astro";
import Products from "../components/Products.astro";
import Quote from "../components/Quote.astro";

const PUBLIC_SITE_LOCALE = import.meta.env.PUBLIC_SITE_LOCALE || "fr";
---

<Layout
  title={data.titleHome}
  metaTitle={data.metaTitleHome}
  description={data.descriptionHome}
>
  <main>
    <HeroHome />
    <Services title="Nos services" label="Expertise" text="Voici nos principaux domaines d'expertise dans le développement web et les agents IA." elements={data.services[PUBLIC_SITE_LOCALE]} />
    {PUBLIC_SITE_LOCALE === 'ch' && <Products />}
    <Advantages />
    <LogoBlock
      title="Les outils maîtrisés"
      label="Stack technique"
      text="Après avoir analysé le besoin de votre projet, nous choisirons ensemble l'outil le plus adapté pour obtenir le meilleur résultat."
      elements={data.tools}
    />
    <LogoBlock
      title="Nos partenaires"
      label="Confiance"
      text="Voici une liste de quelques entreprises avec lesquelles nous travaillons régulièrement. Merci à elles pour leur confiance."
      elements={data.partners}
    />
    <Quote className="-mt-10 mb-10">
      Nous collaborons depuis plusieurs années avec la plupart de nos clients. Ici pas de site jetable, nous nous investissons dans la durée.
    </Quote>
  </main>
</Layout>
