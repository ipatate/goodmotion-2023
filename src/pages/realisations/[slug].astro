---
import { getCollection, render } from "astro:content";
import PageLayout from "../../layouts/PageLayout.astro";
import StructuredData from "../../components/StructuredData.astro";

export async function getStaticPaths() {
  const SITE_LOCALE = import.meta.env.SITE_LOCALE || "fr";
  const allUsecases = await getCollection("usecases");
  return allUsecases
    .filter((entry) => entry.id.startsWith(`${SITE_LOCALE}/`))
    .map((entry) => ({
      params: { slug: entry.id.replace(`${SITE_LOCALE}/`, "") },
      props: { entry },
    }));
}

const { entry } = Astro.props;
const { Content, headings } = await render(entry);
---

<PageLayout
  title={entry.data.title}
  description={entry.data.description}
  metaTitle={entry.data.metaTitle}
  headings={headings}
  frontmatter={entry.data}
  isLocaleOnly={true}
>
  <Content />
</PageLayout>
