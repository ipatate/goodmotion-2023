---
import card from "../../assets/images/sites-Web-et-de-Web-Applications-sur-Annecy-Lyon-Geneve-et-Lausanne.jpg";
import faviconImage from "../../assets/images/favicon.svg";
import Favicon from "./Favicon.astro";
import { getLocaleData } from "../../data";

type Props = {
  title: string;
  metaTitle?: string;
  description: string;
  color?: string;
  isLocaleOnly?: boolean;
};

// remove .html from pathname and normalize /index to /
const rawPathname = new URL(Astro.request.url).pathname.replace(".html", "");
const pathname = rawPathname === "/index" ? "/" : rawPathname;

const SITE_URL = import.meta.env.SITE_URL;
const ALTERNATE_SITE_URL = import.meta.env.ALTERNATE_SITE_URL;
const SITE_LOCALE = import.meta.env.SITE_LOCALE || "fr";

const { title, description, metaTitle, color = "primary", isLocaleOnly = false } = Astro.props;

const localeInfo = getLocaleData(SITE_LOCALE);

// Hreflang URLs
const frUrl = SITE_LOCALE === "fr" ? `${SITE_URL}${pathname}` : `${ALTERNATE_SITE_URL}${pathname}`;
const chUrl = SITE_LOCALE === "ch" ? `${SITE_URL}${pathname}` : `${ALTERNATE_SITE_URL}${pathname}`;
const showHreflang = !isLocaleOnly && !!ALTERNATE_SITE_URL;

let themeColor = "#08556C";
switch (color) {
  case "casper":
    themeColor = "#424d66";
    break;
  case "summer-green":
    themeColor = "#22322d";
    break;
  case "alto":
    themeColor = "#4e4e4e";
    break;
  case "secondary":
    themeColor = "#6b3d23";
    break;
  default:
    themeColor = "#08556C";
    break;
}
---

<title>{metaTitle || title}</title>
<meta name="robots" content="index, follow" />
<meta name="description" content={description} />
<meta content={metaTitle || title} name="twitter:title" />
<meta content={description} name="twitter:description" />
<link rel="icon" type="image/svg+xml" href={faviconImage.src} />
<meta content="@PatrickFaramaz" name="twitter:site" />
<meta content="@PatrickFaramaz" name="twitter:creator" />
<meta name="twitter:card" content="summary_large_image" />
<meta name="twitter:image" content={`${SITE_URL}${card.src}`} />
<meta content={metaTitle || title} name="og:title" />
<meta content={description} name="og:description" />
<meta property="og:type" content="website" />
<meta property="og:image" content={`${SITE_URL}${card.src}`} />
<meta property="og:site_name" content="Goodmotion" />
<meta property="og:locale" content={localeInfo.ogLocale} />
<meta name="theme-color" content={themeColor} />

<link rel="canonical" href={`${SITE_URL}${pathname}`} />
<meta property="og:url" content={`${SITE_URL}${pathname}`} />
<meta property="og:image:width" content="1200" />
<meta property="og:image:height" content="630" />
<link rel="home" href={`${SITE_URL}`} />
<link rel="sitemap" href="/sitemap-index.xml" />

{showHreflang && (
  <>
    <link rel="alternate" hreflang="fr-FR" href={frUrl} />
    <link rel="alternate" hreflang="fr-CH" href={chUrl} />
    <link rel="alternate" hreflang="x-default" href={frUrl} />
  </>
)}

<Favicon />
