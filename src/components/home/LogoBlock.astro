---
import { Image } from "astro:assets";
import type { SvgComponent } from "astro/types";

export interface Props {
  title: string;
  text: string;
  label?: string;
  elements: {
    image: SvgComponent | ImageMetadata;
    title: string;
    class: string;
    place?: string;
    details?: string;
  }[];
}
const { title, text, label, elements } = Astro.props;
const hasDetails = elements.some((e) => e.place || e.details);
---

<div class="flex flex-col py-6 lg:py-10">
  <div class="md:max-w-7xl w-full mx-auto my-2 md:my-5 text-left px-4 md:px-10">
    {
      label && (
        <p class="text-xs font-bold tracking-[0.2em] uppercase text-primary-600 mb-4">
          {label}
        </p>
      )
    }
    <h2
      class="text-5xl sm:text-7xl md:text-8xl text-primary-900 font-extrabold leading-none tracking-tight"
    >
      {title}
    </h2>
    <p
      class="text-left w-full text-base text-primary-900/60 mt-5 mb-6 max-w-2xl"
    >
      {text}
    </p>
  </div>

  {
    hasDetails ? (
      /* Partners */
      <div class="md:max-w-7xl mt-6 mb-20 w-full mx-auto px-4 md:px-10 overflow-hidden">
        <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 -mb-px -mr-px gap-2">
          {elements.map((element) => (
            <div class="flex items-center gap-5 py-5 px-6 bg-neutral-50 rounded">
              <div class="shrink-0 flex items-center justify-center w-20 h-12">
                <Image
                  src={element.image as any}
                  width={element.image.width}
                  height={element.image.height}
                  alt={element.title}
                  class={`${element.class} max-h-10 w-auto object-contain`}
                  loading="lazy"
                  decoding="async"
                />
              </div>
              <div class="min-w-0">
                <p class="text-sm font-semibold text-primary-900 truncate">
                  {element.title}
                </p>
                {element.place && (
                  <p class="text-xs text-primary-900/50 mt-0.5">
                    {element.place}
                  </p>
                )}
                {element.details && (
                  <p class="text-xs text-primary-700 mt-1">{element.details}</p>
                )}
              </div>
            </div>
          ))}
        </div>
      </div>
    ) : (
      /* Tools */
      <div class="md:max-w-7xl mt-6 mb-20 w-full mx-auto px-4 md:px-10 overflow-hidden">
        <div class="grid grid-cols-2 sm:grid-cols-4 lg:grid-cols-5 gap-2 -mb-px -mr-px">
          {elements.map((element) => (
            <div class="flex flex-col items-center justify-center py-8 px-4 rounded bg-neutral-50 gap-3">
              <Image
                src={element.image as any}
                width={element.image.width}
                height={element.image.height}
                alt={element.title}
                class={`${element.class} max-h-10 w-auto object-contain`}
                loading="lazy"
                decoding="async"
              />
              <p class="text-xs font-medium text-primary-900/80">
                {element.title}
              </p>
            </div>
          ))}
        </div>
      </div>
    )
  }
</div>
