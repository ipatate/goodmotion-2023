---
import speed from "../../../assets/images/speed.svg";
import secure from "../../../assets/images/secure.svg";
import green from "../../../assets/images/green.svg";
import { Image } from "astro:assets";

const title = "Nos engagements";
const text =
  "Faire des sites web c'est bien mais faire des sites web rapides, sécurisés et durables c'est mieux !";
const avantages = [
  {
    title: "Des sites web rapides !",
    image: speed,
  },
  {
    title: "Des sites web sécurisés !",
    image: secure,
  },
  {
    title: "Des sites web durables !",
    image: green,
  },
];
---

<div class="flex flex-col pt-5 pb-20">
  <div class="md:max-w-7xl w-full mx-auto my-2 md:my-5 text-left px-4 md:px-10">
    <p
      class="text-xs font-bold tracking-[0.2em] uppercase text-primary-800 mb-4"
    >
      Valeurs
    </p>
    <h2
      class="text-5xl sm:text-7xl md:text-8xl text-primary-900 font-extrabold leading-none tracking-tight"
    >
      {title}
    </h2>
    <p
      class="text-left w-full text-base text-primary-900/60 mt-5 mb-6 max-w-2xl"
    >
      {text}
    </p>
  </div>
  <div
    class="logo-grid grid md:grid-cols-3 md:gap-4 max-w-7xl relative w-full mx-auto md:px-6 mt-5"
  >
    {
      avantages.map((avantage, i) => (
        <div class="flex flex-col flex-1 text-center py-6 md:p-4">
          <Image
            src={avantage.image}
            width={avantage.image.width}
            height={avantage.image.height}
            alt=""
            class="w-44 h-44 md:w-28 md:h-28 mx-auto"
          />
          <h3 class="text-base font-semibold tracking-wide text-primary-900 mt-4 md:mt-6">
            {avantage.title}
          </h3>
        </div>
      ))
    }
  </div>
  <div class="md:max-w-7xl w-full mx-auto px-4 md:px-10 mt-12 md:mt-20">
    <div
      class="border border-primary-900/10 bg-primary-50/50 px-8 py-8 md:py-10 flex flex-col md:flex-row gap-6 md:gap-10 items-start"
    >
      <svg
        xmlns="http://www.w3.org/2000/svg"
        class="shrink-0 mt-1 text-primary-700"
        width="36"
        height="36"
        viewBox="0 0 48 48"
        ><defs
          ><mask id="SVGM7aMbcQo"
            ><g
              fill="none"
              stroke="#fff"
              stroke-linejoin="round"
              stroke-width="4"
              ><path
                fill="#555"
                d="M6 9.256L24.009 4L42 9.256v10.778A26.32 26.32 0 0 1 24.003 45A26.32 26.32 0 0 1 6 20.029z"
              ></path><path stroke-linecap="round" d="m15 23l7 7l12-12"
              ></path></g
            ></mask
          ></defs
        ><path fill="currentColor" d="M0 0h48v48H0z" mask="url(#SVGM7aMbcQo)"
        ></path></svg
      >
      <div>
        <h3 class="text-primary-900 mb-3 font-bold text-xl tracking-tight">
          Sécurité et souveraineté des données
        </h3>
        <p class="text-base leading-relaxed text-primary-900/70">
          Nous utilisons un maximum de solutions européennes pour garantir la
          sécurité et la souveraineté des données de nos clients. En priorité,
          des fournisseurs suisses et français.<br />Proton mail, infomaniak,
          JetBrain, Kilo Code ... font partie de nos outils du quotidien.
        </p>
      </div>
    </div>
  </div>
</div>
