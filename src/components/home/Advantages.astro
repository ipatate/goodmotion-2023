---
import speed from "../../../assets/images/speed.svg";
import secure from "../../../assets/images/secure.svg";
import green from "../../../assets/images/green.svg";
import { Image } from "astro:assets";

const title = "Nos engagements";
const text =
  "Faire des sites web c'est bien mais faire des sites web rapides, sécurisés et durables c'est mieux !";
const avantages = [
  {
    title: "Des sites web rapides !",
    image: speed,
  },
  {
    title: "Des sites web sécurisés !",
    image: secure,
  },
  {
    title: "Des sites web durables !",
    image: green,
  },
];
---

<div class="flex flex-col pt-5 pb-20">
  <div class="md:max-w-7xl w-full mx-auto my-2 md:my-5 text-left px-4 md:px-10">
    <h2
      class="text-5xl sm:text-6xl w-auto md:text-7xl text-primary-900 font-semibold"
    >
      {title}
    </h2>
    <p
      class="max-w-7xl text-left w-full text-base text-gray-700 my-6 font-light"
    >
      {text}
    </p>
  </div>
  <div
    class="logo-grid grid md:grid-cols-3 md:gap-4 max-w-7xl relative w-full mx-auto md:px-6 mt-5"
  >
    {
      avantages.map((avantage, i) => (
        <div class="flex flex-col flex-1 text-center py-6 md:p-4">
          <Image
            src={avantage.image}
            width={avantage.image.width}
            height={avantage.image.height}
            alt=""
            class="w-44 h-44 md:w-28 md:h-28 mx-auto"
          />
          <h3 class="text-lg md:text-2xl text-primary-900 font-light mt-3 md:mt-8">
            {avantage.title}
          </h3>
        </div>
      ))
    }
  </div>
  <div class="md:max-w-6xl w-11/12 md:w-full mx-auto my-2 mt-10 md:mt-25 relative text-left px-4 pb-4 pt-10 border border-gray-200 rounded-md bg-gray-50 flex flex-row gap-4">
    <svg xmlns="http://www.w3.org/2000/svg" class="absolute -top-8 -left-4" width="62" height="62" viewBox="0 0 48 48"><defs><mask id="SVGM7aMbcQo"><g fill="none" stroke="#fff" stroke-linejoin="round" stroke-width="4"><path fill="#555" d="M6 9.256L24.009 4L42 9.256v10.778A26.32 26.32 0 0 1 24.003 45A26.32 26.32 0 0 1 6 20.029z"/><path stroke-linecap="round" d="m15 23l7 7l12-12"/></g></mask></defs><path fill="currentColor" d="M0 0h48v48H0z" mask="url(#SVGM7aMbcQo)"/></svg>
    <div>
    <h3 class="text-primary-900 mb-4 font-semibold text-2xl">Sécurité et souveraineté des données</h3>
    <p class="font-light">Nous utilisons un maximum de solutions européennes pour garantir la sécurité et la souveraineté des données de nos clients. En priorité, des fournisseurs suisses et français.<br/>Proton mail, infomaniak, JetBrain, Kilo Code ... font partie de nos outils du quotidien.</p>
    </div>
  </div>
  </div>
