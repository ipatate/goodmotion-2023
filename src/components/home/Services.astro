---
export interface Props {
	title: string;
	text: string;
	elements: {
		title: string;
		link: string;
		intro: string;
		class: string;
	}[];
}
const { title, text, elements } = Astro.props;
---

<div class="py-6 lg:pb-20">
  <div class="md:max-w-7xl w-full mx-auto my-2 md:my-5 text-left px-4 md:px-10">
    <h2
        class="text-5xl sm:text-6xl w-auto md:text-7xl text-primary-900 font-semibold"
    >
      {title}
    </h2>
    <p
        class="max-w-7xl text-left w-full text-base text-gray-700 my-6 font-light"
    >
      {text}
    </p>
  </div>
  <div
    class="max-w-full md:max-w-7xl mx-auto relative w-full grid grid-cols-1 lg:grid-cols-4 gap-3 pb-4 px-4 md:px-10"
  >
    {
      elements.map((element, index) => (
        <div
          class={`p-10 rounded-md lg:min-h-76 flex gap-5 flex-col justify-center relative ${element.class} group hover:scale-102 hover:z-10 transition-[transform_opacity] duration-300 hover:opacity-90`}
        >
          <h2 class="text-3xl sm:text-4xl lg:text-4xl font-bold text-white/80 lg:leading-[2.7rem] text-balance group-hover:text-white">
            <a href={element.link} class="after:absolute after:inset-0">{element.title}</a>
          </h2>
          <p class="text-white text-lg">{element.intro}</p>
        </div>
      ))
    }
  </div>
</div>
