---
import HeroPage from "../components/HeroPage.astro";
import Toc from "../components/Toc.astro";
import BaseLayout from "./BaseLayout.astro";

export interface Props {
  title?: string;
  metaTitle?: string;
  description?: string;
  headings?: any[];
  frontmatter?: Record<string, any>;
  isLocaleOnly?: boolean;
}

const { headings, frontmatter = {}, isLocaleOnly = false } = Astro.props;

const SITE_LOCALE = import.meta.env.SITE_LOCALE || "fr";
const localeKey = SITE_LOCALE.charAt(0).toUpperCase() + SITE_LOCALE.slice(1);

// Locale-aware frontmatter fields: frontmatter.subtitleFr / subtitleCh, etc.
function lf(field: string): string | undefined {
  return frontmatter[`${field}${localeKey}`] ?? frontmatter[field];
}

// Merge explicit props with frontmatter (explicit props take precedence)
const title = Astro.props.title ?? lf("title") ?? "";
const description = Astro.props.description ?? lf("description") ?? "";
const metaTitle = Astro.props.metaTitle ?? lf("metaTitle");

const randomColor: Color = "casper";
---

<BaseLayout
  title={title}
  description={description}
  metaTitle={metaTitle}
  color={randomColor}
  isLocaleOnly={isLocaleOnly}
>
  <HeroPage
    title={frontmatter.title ?? title}
    subtitle={lf("subtitle")}
    color={randomColor}
  />
  <div
    class="prose prose-lg mx-auto pt-0 pb-20 px-4 md:px-10 max-w-5xl page-content relative"
  >
    <Toc
      headings={headings}
      color={randomColor}
      showToc={frontmatter.showToc}
    />
    <slot />
  </div>
</BaseLayout>
