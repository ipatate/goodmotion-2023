---
import "../styles/global.css";
import { ClientRouter } from "astro:transitions";
import Seo from "../components/Seo.astro";
import StructuredData from "../components/StructuredData.astro";
import Footer from "../components/Footer.astro";
import Header from "../components/Header.astro";
import Co2badge from "../components/Co2badge.astro";
import fontSora from "../../assets/fonts/Sora-VariableFont_wght.woff2";
import { getLocaleData } from "../../data";

export interface Props {
  title: string;
  metaTitle?: string;
  description: string;
  color?: Color;
  isLocaleOnly?: boolean;
}

const SITE_LOCALE = import.meta.env.SITE_LOCALE || "fr";
const localeInfo = getLocaleData(SITE_LOCALE);

const { title, description, metaTitle, color = "primary", isLocaleOnly = false } = Astro.props;

// Get pathname for breadcrumb schema
const rawPathname = new URL(Astro.request.url).pathname.replace(".html", "");
const pathname = rawPathname === "/index" ? "/" : rawPathname;
---

<!doctype html>
<html lang={localeInfo.htmlLang}>
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width" />
    <link
      rel="preload"
      href={fontSora}
      as="font"
      type="font/woff2"
      crossorigin
    />
    <link rel="preconnect" href="https://analytics.senciel.org" />
    <Seo
      title={title}
      metaTitle={metaTitle}
      description={description}
      color={color}
      isLocaleOnly={isLocaleOnly}
    />

    <!-- Structured Data Schemas -->
    <StructuredData type="Organization" />
    <StructuredData type="LocalBusiness" />
    <StructuredData type="WebSite" />
    {
      pathname !== "/" && (
        <StructuredData type="BreadcrumbList" pathname={pathname} />
      )
    }
    <ClientRouter />
    <script
      defer
      data-domain={localeInfo.plausibleDomain}
      src="https://analytics.senciel.org/js/script.js"></script>
    <script is:inline>
      window.plausible =
        window.plausible ||
        function () {
          (window.plausible.q = window.plausible.q || []).push(arguments);
        };
    </script>
  </head>

  <body class="bg-white">
    <div class="h-screen absolute top-0 right-0 left-0 z-[-1]"></div>
    <Header color={color} />
    <Co2badge />
    <slot />
    <Footer />
  </body>
</html>
